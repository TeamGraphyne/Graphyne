generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Graphic {
  id        String  @id @default(uuid())
  name      String
  thumbnail String?
  filePath  String

  rawJson String @db.Text // Stringified JSON source

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A Graphic can be in many Projects (Playlists)
  projects PlaylistItem[]
}

model Project {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A Project is a ordered list of Graphics
  items PlaylistItem[]

  // A Project owns its Data Sources
  dataSources DataSource[]
}

model PlaylistItem {
  id String @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  graphic   Graphic @relation(fields: [graphicId], references: [id])
  graphicId String

  order Int
}

model DataSource {
  id        String  @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  name      String   // label
  type      String   // "rest-api" | "json-file" | "csv-file"

  // Connection configuration (varies by type, stored as JSON string)
  config    String   @db.Text  // JSON

  // Polling
  pollingInterval Int     @default(0)   // Seconds. 0 = manual refresh only
  autoStart       Boolean @default(false)

  // Cached schema for UI dropdowns (auto-detected)
  fields    String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}