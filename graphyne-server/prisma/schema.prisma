generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "darwin", "darwin-arm64", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}
datasource db {
  // MODIFIED: Switched from postgresql to sqlite for local-first deployment
  // No Docker required — DB is a file at the path specified by DATABASE_URL
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Graphic {
  id        String  @id @default(uuid())
  name      String
  thumbnail String?
  filePath  String

  rawJson String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A Graphic can be in many Projects (Playlists)
  projects PlaylistItem[]
}

model Project {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A Project is a ordered list of Graphics
  items PlaylistItem[]

  // A Project owns its Data Sources
  dataSources DataSource[]
}

model PlaylistItem {
  id String @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  graphic   Graphic @relation(fields: [graphicId], references: [id])
  graphicId String

  order Int
}

model DataSource {
  id        String @id @default(uuid())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  name      String   // label
  type      String   // "rest-api" | "json-file" | "csv-file"

  // MODIFIED: Removed @db.Text — not supported by SQLite provider
  config String   // JSON string

  // Polling
  pollingInterval Int     @default(0)   // Seconds. 0 = manual refresh only
  autoStart       Boolean @default(false)

  // MODIFIED: Removed @db.Text
  fields String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  type        String   // "image" | "video" | "font"
  mimeType    String
  filePath    String
  fileSize    Int
  altText     String?
  tags       String   @default("") // stored as array
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Hotkey {
  id        String   @id @default(cuid())
  action    String
  keys      String   @unique
  isCustom  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Licensing Model ─────────────────────────────────────────────────────────

model License {
  id             String   @id @default(cuid())
  licenseKey     String   @unique
  deviceId       String   
  isValid        Boolean  @default(false)
  expirationDate DateTime?
  activatedAt    DateTime @default(now())
}

// ─── Better Auth Required Models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Role for local RBAC (e.g., "admin", "editor", "playout")
  role          String    @default("editor")

  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  expiresAt             DateTime?
  password              String?   
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}