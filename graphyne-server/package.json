{
  "name": "graphyne-server",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "build:binary": "node scripts/bundle-migrations.js && npm run build && node scripts/build-sidecar.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^7.0.1",
    "@prisma/client": "^5.10.2",
    "fastify": "^4.26.1",
    "font-list": "^2.0.2",
    "fs-extra": "^11.2.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "@yao-pkg/pkg": "^5.12.0",
    "prisma": "^5.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "assets": [
      "node_modules/.prisma/client/query_engine-*",
      "node_modules/@prisma/client/runtime/**",
      "prisma/schema.prisma",
      "node_modules/font-list/**"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-win-x64"
    ],
    "outputPath": "binaries"
  }
}
