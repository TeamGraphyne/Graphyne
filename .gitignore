# ── Tauri generated artefacts (must not be committed) ─────────────────────────
# These are produced by the build pipeline and placed here by build-sidecar.js /
# the release workflow. They are platform-specific and large; .gitignore them so
# developers don't accidentally commit binaries.

# Compiled server sidecar binaries
/graphyne-launcher/src-tauri/binaries/

# React client build copied into Tauri resources
/graphyne-launcher/src-tauri/client/

# Rust build output
/graphyne-launcher/src-tauri/target/

# pkg intermediate binaries
/graphyne-server/binaries/
-e 
